# Frontend production environment — usado por `vite build` cuando
# `npm run build` se ejecuta con NODE_ENV=production (default).
#
# Copia a `.env.production` y ajusta la URL del backend al dominio real
# de la VM con TLS de Let's Encrypt (Caddy).
#
# Ejemplo:
#   VITE_API_BASE_URL=https://tutor.iestprfa.edu.pe/api/v1

VITE_API_BASE_URL=https://REEMPLAZAR_DOMINIO_BACKEND/api/v1
